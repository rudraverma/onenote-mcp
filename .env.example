# onenote-mcp environment variables
# Copy this file to .env and fill in your values.
# Never commit .env — it contains your Azure credentials.

# Azure app Client ID (required)
# Get this from: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
ONENOTE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Tenant ID (work/school accounts only)
# Leave as "common" for personal Microsoft accounts (Outlook, Hotmail, Live)
# For work/school: Azure portal → Azure Active Directory → Overview → Tenant ID
ONENOTE_TENANT=common

# SharePoint Site ID (enterprise accounts with >5000 OneNote items only)
# Required if you get Graph API error 10008 (OneDrive library too large)
# Format: hostname,siteId,webId
# ONENOTE_SITE_ID=yourorg-my.sharepoint.com,xxxxxxxx-...,xxxxxxxx-...
